# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Environment / secrets. The checked-in env.{flavor}.json files are
# templates; .env.local / env.*.local / .env files hold real secrets and
# must never be committed.
.env
.env.local
.env.*.local
*.env.json
!env.example.json
!env.dev.json
!env.staging.json
!env.prod.json

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android release signing config (keeps the keystore out of version control)
# - `key.properties.example` is the template checked in; copy it to
#   `key.properties` and fill in your keystore credentials.
/android/key.properties
/android/app/*.jks
/android/app/*.keystore

# Firebase / FCM config files. The placeholder files in
# android/app/src/{flavor}/ and ios/Runner/{Dev,Staging,Prod}/ are not
# committed — copy `*-example.plist` / `google-services.json.example`
# locally and populate with your real Firebase project credentials.
/android/app/src/*/google-services.json
!/android/app/src/*/google-services.json.example
/ios/Runner/*/GoogleService-Info.plist
!/ios/Runner/*/GoogleService-Info.plist.example


